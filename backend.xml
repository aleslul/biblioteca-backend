spring.application.name=biblioteca
server.port=8081

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

spring.datasource.url=jdbc:mysql://${MYSQL_HOST:localhost}:3306/dbbiblioteca
spring.datasource.username=root
spring.datasource.password=

# --- CONFIGURACIÓN DE JWT ---
# Llave secreta encriptada en Base64 (Debe tener al menos 256 bits para HMAC-SHA256)
jwt.secret=QnJpZ2h0QmlibGlvdGVjYVNlY3JldEtleTIwMjYxMjM0NTY3ODk=
# Tiempo de expiración en milisegundos (86400000 ms = 24 horas)
jwt.expiration-ms=86400000

# --- CONFIGURACIÓN DE PRÉSTAMOS (RF-07) ---
# Horas antes del vencimiento en las que se permite renovar un libro
app.prestamos.horas-ventana-renovacion=48
# Cantidad de días que se extiendel el préstamo al renovar
app.prestamos.dias-extension-renovacion=7

# --- CONFIGURACIÓN DE CORREO INSTITUCIONAL (RF-01) ---
# Dominio requerido para registrarse en la plataforma
app.correo.dominio-institucional=@uss.edu.pe

# --- CONFIGURACIÓN DE NOTIFICACIONES (RF-10) ---
# Horas de anticipación para avisar que un préstamo va a vencer
app.notificaciones.horas-anticipacion-vencimiento=24
# Tarea programada (Cron): Ejecutar la revisión todos los días a las 08:00 AM
app.notificaciones.cron-revision-diaria=0 0 8 * * *
